# ============================================================
# FarmAI — Environment Variables
# ============================================================
# Copy this to .env and fill in your values
# cp .env.example .env

# ── Anthropic (REQUIRED) ────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database (PostgreSQL + pgvector) ────────────────────────
# Used for: RAG vector store + farmer memory + history
POSTGRES_URL=postgresql://farmai:farmai123@localhost:5432/farmai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=farmai
POSTGRES_USER=farmai
POSTGRES_PASSWORD=farmai123

# ── Redis (Cache + Rate Limiting) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── External APIs ───────────────────────────────────────────
# Weather: https://openweathermap.org/api (free tier works)
OPENWEATHER_API_KEY=your-openweather-key-here

# India Mandi prices — we use mock data if not set
AGMARKNET_API_KEY=optional-if-you-have-it

# ── MCP Server ──────────────────────────────────────────────
# This is WHERE the MCP server runs (for clients to connect)
MCP_SERVER_URL=http://localhost:8001/sse
MCP_SERVER_PORT=8001

# ── FastAPI Backend ─────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0

# ── App Settings ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── BFF Service ─────────────────────────────────────────────
BFF_PORT=8002
BFF_BASE_URL=http://localhost:8002

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your-32-char-secret-here

# OTP via Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google Cloud Translation (https://console.cloud.google.com)
GOOGLE_TRANSLATE_API_KEY=your-google-api-key-here

# Audio file storage (default is fine for dev)
AUDIO_DIR=/tmp/audio
AUDIO_TTL_HOURS=1
